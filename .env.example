# Sentinel Trading Platform — Environment Variables
# Copy to .env and fill in your values

# === Alpaca (Equities) ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === Coinbase (Crypto) ===
COINBASE_API_KEY=
COINBASE_API_SECRET=

# === Polymarket (Prediction Markets) ===
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=

# === Kalshi (Prediction Markets) ===
KALSHI_API_KEY=
KALSHI_BASE_URL=https://demo-api.kalshi.co

# === Claude API (Learning Engine) ===
ANTHROPIC_API_KEY=

# === Database ===
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_dev@localhost:5432/sentinel

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Alerts ===
DISCORD_WEBHOOK_URL=

# === Risk Config Overrides (optional) ===
# RISK_HARD_FLOOR_PCT=90.0
# RISK_MAX_DAILY_LOSS_PCT=3.0
# RISK_MAX_POSITION_PCT=10.0
